function nav(p){
  page=p;
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));
  document.getElementById('nb-'+p).classList.add('on');
  const titles={home:'Accueil',train:'Entraînement',track:'Suivi charges & cardio',nutri:'Nutrition',courses:'Liste de courses'};
  document.getElementById('tb-title').textContent=titles[p];
  render();
}
function render(){
  const c=document.getElementById('content');
  if(page==='home') c.innerHTML=renderHome();
  else if(page==='train') c.innerHTML=renderTrain();
  else if(page==='track') c.innerHTML=renderTrack();
  else if(page==='nutri') c.innerHTML=renderNutri();
  else if(page==='courses') c.innerHTML=renderCourses();
}

