.trk-table td{padding:4px 4px}
.trk-input{background:var(--bg3);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:14px;font-weight:600;width:100%;padding:7px 6px;text-align:center;-webkit-appearance:none;appearance:none}
.trk-input:focus{outline:none;border-color:var(--red)}
.trk-date{font-size:11px;color:var(--muted);padding:5px 4px;vertical-align:middle}
.btn-add{background:var(--bg3);border:1px dashed var(--border);border-radius:10px;color:var(--muted);font-size:13px;font-weight:600;width:100%;padding:10px;cursor:pointer;margin-top:4px}
.btn-add:active{background:var(--bg2)}
