*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:-apple-system,'SF Pro Text',sans-serif;overflow:hidden}
#app{display:flex;flex-direction:column;height:100vh;height:-webkit-fill-available}
#topbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:12px 16px 10px;flex-shrink:0;padding-top:max(14px,env(safe-area-inset-top))}
.tb-eyebrow{font-size:11px;font-weight:600;letter-spacing:1.4px;color:var(--muted);text-transform:uppercase}
.tb-title{font-size:18px;font-weight:800;color:var(--text);margin-top:1px}
#content{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:14px 14px 100px}
#navbar{position:fixed;bottom:0;left:0;right:0;background:var(--bg2);border-top:1px solid var(--border);display:flex;padding-bottom:max(10px,env(safe-area-inset-bottom));z-index:200}
.nb{flex:1;display:flex;flex-direction:column;align-items:center;padding:10px 0 4px;cursor:pointer;user-select:none}
.nb-ico{font-size:18px;margin-bottom:2px}
.nb-lbl{font-size:9px;font-weight:600;color:var(--muted);letter-spacing:0.2px}
.nb.on .nb-lbl{color:var(--red)}
.chips{display:flex;gap:7px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;margin-bottom:14px}
.chips::-webkit-scrollbar{display:none}
.chip{flex-shrink:0;padding:7px 14px;border-radius:20px;font-size:13px;font-weight:600;background:var(--bg3);color:var(--muted);cursor:pointer;border:1.5px solid transparent;transition:all .15s}
.chip.on{background:var(--red);color:#fff;border-color:var(--red)}
.chip.on2{border-color:var(--red);color:var(--text)}
.card{background:var(--card);border-radius:var(--r);border:1px solid var(--border);padding:14px;margin-bottom:10px}
.card-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:11px}
.card-title{font-size:14px;font-weight:700}
.bdg{font-size:11px;padding:3px 9px;border-radius:7px;font-weight:600}
.bdg-r{background:rgba(230,57,70,.18);color:var(--red)}
.bdg-b{background:rgba(59,130,246,.18);color:var(--blue)}
.bdg-g{background:rgba(34,197,94,.18);color:var(--green)}
.bdg-o{background:rgba(245,158,11,.18);color:var(--orange)}
.bdg-p{background:rgba(167,139,250,.18);color:var(--purple)}
.bdg-t{background:rgba(20,184,166,.18);color:var(--teal)}
.bdg-gr{background:var(--bg3);color:var(--muted)}
.slbl{font-size:10px;font-weight:700;letter-spacing:1.2px;color:var(--red);text-transform:uppercase;margin:10px 0 5px}
.exrow{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.exrow:last-child{border-bottom:none}
.ex-n{font-size:13px;color:var(--text);flex:1;padding-right:8px}
.ex-d{font-size:11px;color:var(--muted);text-align:right}
.ex-must{font-size:11px;color:var(--blue);font-weight:700;text-align:right}
.cblock{background:rgba(34,197,94,.07);border:1px solid rgba(34,197,94,.2);border-radius:12px;padding:12px;margin-bottom:10px}
.cblock-title{font-size:11px;font-weight:700;color:var(--green);letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px}
