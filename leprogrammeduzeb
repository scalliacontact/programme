.meal-name{font-size:14px;font-weight:700}
.meal-time{font-size:12px;color:var(--muted)}
.frow{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:13px}
.frow:last-child{border-bottom:none}
.fqty{color:var(--muted);font-size:12px}
.macros-row{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}
.mm{font-size:11px;padding:2px 7px;border-radius:6px;font-weight:700}
.mm-p{background:rgba(59,130,246,.15);color:var(--blue)}
.mm-g{background:rgba(245,158,11,.15);color:var(--orange)}
