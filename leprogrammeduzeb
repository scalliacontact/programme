.hero-sub{font-size:13px;color:rgba(255,255,255,.7);margin-top:4px;line-height:1.5}
.pgbar-bg{height:8px;background:rgba(255,255,255,.2);border-radius:4px;overflow:hidden;margin-top:12px}
.pgbar-fill{height:100%;background:#fff;border-radius:4px}
.pgbar-lbl{font-size:11px;color:rgba(255,255,255,.65);margin-top:5px;display:flex;justify-content:space-between}
.rules-card{background:var(--card);border-radius:var(--r);border:1px solid var(--border);padding:14px;margin-bottom:10px}
.rule-item{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid var(--border);align-items:flex-start}
.rule-item:last-child{border-bottom:none}
.rdot{width:7px;height:7px;border-radius:50%;background:var(--red);flex-shrink:0;margin-top:5px}
.rtext{font-size:13px;line-height:1.55}
.sep{height:1px;background:var(--border);margin:4px 0 10px}
