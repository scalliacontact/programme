        <div style="font-size:9px;color:var(--text);font-weight:700">${v}</div>
        <div style="width:100%;height:${ht}px;background:var(--blue);border-radius:3px 3px 0 0"></div>
        <div style="font-size:9px;color:var(--muted);writing-mode:vertical-lr;transform:rotate(180deg);height:32px">${(r.date||'').substring(0,5)}</div>
      </div>`;
    });
    h+=`</div></div>`;
  }
  return h;
}
function addPoidsRow(){
  const key='poids_log';
  const rows=load(key,[]);
  const now=new Date();
  rows.push({date:`${String(now.getDate()).padStart(2,'0')}/${String(now.getMonth()+1).padStart(2,'0')}/${now.getFullYear()}`,poids:''});
  save(key,rows);render();
}
function updatePoidsRow(idx,field,val){const key='poids_log';const rows=load(key,[]);if(rows[idx])rows[idx][field]=val;save(key,rows);}
function deletePoidsRow(idx){const key='poids_log';const rows=load(key,[]);rows.splice(idx,1);save(key,rows);render();}

// ═══════════════════════════════════════════
//  NUTRITION
// ═══════════════════════════════════════════
function renderNutri(){
  let h=`<div class="chips">`;
  WEEKS.forEach((w,i)=>{h+=`<div class="chip ${i===nutriWeek?'on':''}" onclick="setNutriWeek(${i})">Sem.${w.n}</div>`;});
  h+=`</div><div class="chips">`;
  DAYS.forEach((d,i)=>{h+=`<div class="chip ${i===nutriDay?'on2':''}" onclick="setNutriDay(${i})">${d.substring(0,3)}</div>`;});
  h+=`</div>`;
  const isRest=nutriDay===6;
  const kcal=isRest?1900:2150;
  h+=`<div class="dtotal">
    <div class="dtitem"><span class="dtlbl">Protéines</span><span class="dtval" style="color:var(--blue)">190-200g</span></div>
    <div class="dtitem"><span class="dtlbl">Glucides</span><span class="dtval" style="color:var(--orange)">${isRest?'170':'215'}g</span></div>
    <div class="dtitem"><span class="dtlbl">Lipides</span><span class="dtval" style="color:var(--green)">55-60g</span></div>
    <div class="dtitem"><span class="dtlbl">Total cible</span><span class="dtval" style="color:var(--red)">${kcal} kcal</span></div>
  </div>`;
  const pdIdx=nutriDay%7;
  const protDin=PROT_DIN[nutriWeek][pdIdx];
  const protSou=PROT_SOU[nutriWeek][pdIdx];
  const carbDin=CARB_DIN[nutriDay];
  const carbSou=CARB_SOU[nutriDay];
  const veg1=VEG[nutriDay];
  const veg2=VEG[(nutriDay+2)%7];
  const meals=[
    {name:'Déjeuner',time:'7h–8h',badge:'bdg-b',
      optA:{label:'Option A — Flocons',foods:[{n:'Flocons d\'avoine protéinés',q:'70 g'},{n:'Eau ou lait demi-écrémé',q:'200 ml'},{n:'Banane ou fruit',q:'1 moyen'}],p:27,g:68,l:5,k:425},
      optB:{label:'Option B — Yaourts',foods:[{n:'Yaourt nature protéiné',q:'2 pots · 40g prot'},{n:'Amandes',q:'15 g'},{n:'Fruits rouges ou banane',q:'100 g'}],p:42,g:38,l:10,k:400}
    },
    {name:'Collation pré-séance',time:'12h–13h',badge:'bdg-o',
      foods:[{n:'Boisson protéinée Lidl ou whey',q:'1 · 35g prot'},{n:'Galettes de riz',q:'2 galettes'},{n:'Noix ou amandes',q:'15 g'}],p:37,g:22,l:9,k:310
    },
    {name:'Dîner — post-séance',time:'16h–17h30',badge:'bdg-g',
      foods:[{n:protDin,q:''},{n:carbDin,q:''},{n:veg1,q:''},{n:'Huile d\'olive',q:'1 c.s.'}],p:52,g:82,l:16,k:680
    },
    {name:'Souper',time:'19h30–21h',badge:'bdg-p',
      foods:[{n:protSou,q:''},{n:carbSou,q:''},{n:veg2,q:''},{n:'Huile d\'olive',q:'1 c.s.'}],p:50,g:78,l:18,k:660
    }
  ];
  h+=`<div class="card">`;
  meals.forEach(m=>{
    h+=`<div class="meal-section"><div class="meal-hdr"><span class="meal-name">${m.name}</span><span class="bdg ${m.badge}">${m.time}</span></div>`;
    if(m.optA){
      h+=`<div class="optlbl opt-a">${m.optA.label}</div>`;
      m.optA.foods.forEach(f=>{h+=`<div class="frow"><span>${f.n}</span><span class="fqty">${f.q}</span></div>`;});
      h+=`<div class="macros-row"><span class="mm mm-p">${m.optA.p}g P</span><span class="mm mm-g">${m.optA.g}g G</span><span class="mm mm-l">${m.optA.l}g L</span><span class="mm mm-k">${m.optA.k}kcal</span></div>`;
      h+=`<div class="optlbl opt-b" style="margin-top:10px">${m.optB.label}</div>`;
      m.optB.foods.forEach(f=>{h+=`<div class="frow"><span>${f.n}</span><span class="fqty">${f.q}</span></div>`;});
      h+=`<div class="macros-row"><span class="mm mm-p">${m.optB.p}g P</span><span class="mm mm-g">${m.optB.g}g G</span><span class="mm mm-l">${m.optB.l}g L</span><span class="mm mm-k">${m.optB.k}kcal</span></div>`;
    } else {
      m.foods.forEach(f=>{h+=`<div class="frow"><span>${f.n}</span><span class="fqty">${f.q}</span></div>`;});
      h+=`<div class="macros-row"><span class="mm mm-p">${m.p}g P</span><span class="mm mm-g">${m.g}g G</span><span class="mm mm-l">${m.l}g L</span><span class="mm mm-k">${m.k}kcal</span></div>`;
    }
    h+=`</div><div class="sep"></div>`;
  });
  h+=`</div>`;
  h+=`<div class="tipbox"><div class="tiptitle">Conseil semaine ${nutriWeek+1}</div><div class="tiptext">${NUTRI_TIPS[nutriWeek]}</div></div>`;
  if(isRest){
    h+=`<div class="tipbox" style="background:rgba(59,130,246,.07);border-color:rgba(59,130,246,.2)">
      <div class="tiptitle" style="color:var(--blue)">Dimanche — repos</div>
      <div class="tiptext" style="color:rgba(100,160,255,.85)">Réduire portions de 15%. Cible 1900 kcal. Pas de shaker. Batch cooking pour la semaine.</div>
    </div>`;
  }
  return h;
}
function setNutriWeek(i){nutriWeek=i;render();}
function setNutriDay(i){nutriDay=i;render();}

// ═══════════════════════════════════════════
//  COURSES
// ═══════════════════════════════════════════
function renderCourses(){
  const checked=load('courses_checked',{});
  const total=SHOPPING.reduce((s,c)=>s+c.items.length,0);
  const done=Object.values(checked).filter(Boolean).length;
  let h=`<div class="card">
    <div class="card-hdr"><span class="card-title">Liste de courses</span><span class="bdg bdg-g">${done}/${total}</span></div>
    <div style="height:6px;background:var(--bg3);border-radius:3px;overflow:hidden">
      <div style="height:100%;width:${Math.round((done/total)*100)}%;background:var(--green);border-radius:3px"></div>
    </div>
    <div style="font-size:11px;color:var(--muted);margin-top:5px">${done===total?'✅ Tout acheté !':'Coche au fur et à mesure de tes achats'}</div>
  </div>`;
  SHOPPING.forEach(cat=>{
    h+=`<div class="courses-cat">${cat.cat}</div>`;
    cat.items.forEach(item=>{
      const isDone=!!checked[item.id];
      h+=`<div class="courses-item" onclick="toggleCourse('${item.id}')">
        <div class="courses-check ${isDone?'done':''}">${isDone?'✓':''}</div>
        <span class="courses-name ${isDone?'done':''}">${item.name}</span>
        <span class="courses-qty">${item.qty}</span>
      </div>`;
    });
  });
  h+=`<button class="courses-reset" onclick="resetCourses()">🔄 Réinitialiser la liste</button>`;
  return h;
}
function toggleCourse(id){
  const checked=load('courses_checked',{});
  checked[id]=!checked[id];
  save('courses_checked',checked);
  render();
}
function resetCourses(){
  save('courses_checked',{});
  render();
}

