.courses-item{display:flex;align-items:center;gap:12px;padding:10px 12px;background:var(--bg3);border-radius:10px;margin-bottom:6px;cursor:pointer}
.courses-check{width:22px;height:22px;border-radius:6px;border:2px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;transition:all .15s}
.courses-check.done{background:var(--green);border-color:var(--green)}
.courses-name{font-size:13px;color:var(--text);flex:1}
.courses-name.done{color:var(--muted);text-decoration:line-through}
.courses-qty{font-size:11px;color:var(--muted)}
.courses-reset{background:var(--bg3);border:1px solid var(--border);border-radius:10px;color:var(--muted);font-size:13px;font-weight:600;width:100%;padding:10px;cursor:pointer;margin-top:10px}
</style>
</head>
