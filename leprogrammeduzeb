function getBestRowIdx(rows){
  if(!rows.length) return -1;
  let best=-1,bestScore=0;
  rows.forEach((r,i)=>{
    const s=(parseFloat(r.poids)||0)*(parseInt(r.reps)||1)*(parseInt(r.series)||1);
    if(s>bestScore){bestScore=s;best=i;}
  });
  return best;
}
